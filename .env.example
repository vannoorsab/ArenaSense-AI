# ============================================================
#  ArenaSense AI — Environment Variables
#  Copy this file to .env.local and fill in your values
# ============================================================

# Google Cloud Project
GOOGLE_CLOUD_PROJECT=ardent-bulwark-448011-i1
GOOGLE_CLOUD_REGION=asia-south1

# Google Cloud Vision AI (for crowd detection)
CLOUD_VISION_API_KEY=AIzaSyD2cngWl-PymEj1nb53931Gp747k_F3bf8
CLOUD_VISION_ENDPOINT=https://vision.googleapis.com/v1

# Vertex AI (for predictive analytics)
VERTEX_AI_ENDPOINT=https://us-central1-aiplatform.googleapis.com
VERTEX_AI_MODEL_ID=your-model-id

# Application
NEXT_PUBLIC_APP_URL=https://areansense-ai-xxxx-uc.a.run.app
NEXT_PUBLIC_APP_NAME=ArenaSense AI
NEXT_PUBLIC_ENABLE_3D=true
NEXT_PUBLIC_ENABLE_AI_VISION=true

# Alert system (set to 'pusher' for production real-time, 'localStorage' for demo)
NEXT_PUBLIC_ALERT_TRANSPORT=localStorage

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
